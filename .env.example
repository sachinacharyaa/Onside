# ─── TxLINE (txodds) live feed — World Cup free tier ───
# Run `npm run txline:subscribe` (needs a funded devnet wallet) to fill
# TXLINE_API_URL + TXLINE_API_TOKEN automatically, then
# `npm run txline:fixtures` to pick a fixture id.
TXLINE_NETWORK=devnet                            # devnet | mainnet
TXLINE_API_URL=https://txline-dev.txodds.com     # mainnet: https://txline.txodds.com
TXLINE_API_TOKEN=                                # from /api/token/activate
TXLINE_FIXTURE_ID=                               # from `npm run txline:fixtures`
TXLINE_SERVICE_LEVEL=1                           # 1 = free tier (mainnet 12 = real-time free WC tier)

# ─── Solana settlement ───
SOLANA_RPC_URL=https://api.devnet.solana.com
# base58-encoded devnet keypair secret, funded via faucet (used for both the
# TxLINE subscribe tx and the settlement tx).
# Leave empty to run settlement in SIMULATED mode (demo never breaks).
AGENT_WALLET_SECRET_KEY=
# Deployed Anchor program id. Leave empty to fall back to a Memo-program
# proof transaction (still a real, clickable devnet tx).
ANCHOR_PROGRAM_ID=

# ─── Agent behaviour ───
USE_REPLAY_MODE=true       # flip to false once TXLINE_API_TOKEN + TXLINE_FIXTURE_ID are set
REPLAY_FILE=               # optional file in packages/ingestion/replay-data (e.g. txline-123.json from `npm run txline:record`)
CONFIDENCE_SETTLE_THRESHOLD=80
REPLAY_INTERVAL_MS=1500    # ms between replayed events (demo pacing)
