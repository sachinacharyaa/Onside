{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": false,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@onside/agent-runtime": ["../../packages/agent-runtime/src/index.ts"],
      "@onside/ingestion": ["../../packages/ingestion/src/index.ts"],
      "@onside/narration-engine": ["../../packages/narration-engine/src/index.ts"],
      "@onside/settlement": ["../../packages/settlement/src/settler.ts"],
      "@onside/signal-engine": ["../../packages/signal-engine/src/index.ts"]
    }
  },
  "include": ["src", "server", "vite.config.ts"]
}
