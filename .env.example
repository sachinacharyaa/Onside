# ─── TxLINE (txodds) live feed — World Cup free tier ───
# Run `npm run txline:subscribe` (needs a funded devnet wallet) to fill
# TXLINE_API_URL + TXLINE_API_TOKEN automatically, then
# `npm run txline:fixtures` to pick a fixture id.
TXLINE_NETWORK=devnet                            # devnet | mainnet
TXLINE_API_URL=https://txline-dev.txodds.com     # mainnet: https://txline.txodds.com
TXLINE_API_TOKEN=                                # from /api/token/activate
TXLINE_FIXTURE_ID=                               # from `npm run txline:fixtures`
TXLINE_SERVICE_LEVEL=1                           # 1 = free tier (mainnet 12 = real-time free WC tier)

# ─── Solana settlement ───
SOLANA_RPC_URL=https://api.devnet.solana.com
# base58-encoded funded devnet keypair secret (required for real settlement).
# Generate with: npm run wallet:generate  then fund via faucet / airdrop.
# Settlement FAILS loudly if this is empty or unfunded — never fabricates a tx.
AGENT_WALLET_SECRET_KEY=
# Deployed Anchor program id. Leave empty to use a Memo-program proof tx
# (still a real, clickable Solana Explorer link with match/outcome JSON).
ANCHOR_PROGRAM_ID=

# ─── Agent behaviour ───
USE_REPLAY_MODE=true       # flip to false once TXLINE_API_TOKEN + TXLINE_FIXTURE_ID are set
REPLAY_FILE=               # optional; default sample-match.json is the recorded WC 3rd-place demo
CONFIDENCE_SETTLE_THRESHOLD=80
REPLAY_SPEED=60            # compress real timestamps (60× ≈ 2 min for a full match)
REPLAY_INTERVAL_MS=1500    # used only when REPLAY_SPEED is unset / 0 (fixed gap)

# ─── Vercel ───
# Set these in the Vercel project → Settings → Environment Variables (Production).
# Hobby plan functions time out at ~60s — use REPLAY_SPEED=120 (or higher) so a
# full replay finishes before maxDuration. Pro can keep 60 with maxDuration 300.
