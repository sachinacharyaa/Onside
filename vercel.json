{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "npm run build --workspace=web",
  "outputDirectory": "apps/web/dist",
  "functions": {
    "api/stream.ts": {
      "maxDuration": 300,
      "includeFiles": "{packages/**,apps/web/server/**,node_modules/@onside/**}"
    },
    "api/wallet.ts": {
      "maxDuration": 10,
      "includeFiles": "apps/web/server/light-api.ts"
    },
    "api/settlement/latest.ts": {
      "maxDuration": 10,
      "includeFiles": "apps/web/server/light-api.ts"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
